diff --git a/ViScannerService/src/main/kotlin/com/example/scanners/AbstractScanner.kt b/ViScannerService/src/main/kotlin/com/example/scanners/AbstractScanner.kt
--- a/ViScannerService/src/main/kotlin/com/example/scanners/AbstractScanner.kt
+++ b/ViScannerService/src/main/kotlin/com/example/scanners/AbstractScanner.kt
@@ -1,9 +1,15 @@
+enum class ScannerWorkState { ENABLED, DISABLED }
 abstract class AbstractScanner {
   protected var needScan = true
+  protected var scannerWorkState = ScannerWorkState.ENABLED
   protected var listeners: List<ScannerListener> = emptyList()
   fun sendBarcodeToClients(barcode: String) {
+    if (scannerWorkState == ScannerWorkState.DISABLED) { listeners.forEach { it.onDisabledScanAttempt() }; return }
     if (needScan) listeners.forEach { it.onScan(barcode) }
   }
+  open suspend fun enableScanner() { scannerWorkState = ScannerWorkState.ENABLED; needScan = true; setStandardBeepEnabled(true) }
+  open suspend fun disableScanner() { scannerWorkState = ScannerWorkState.DISABLED; needScan = false; setStandardBeepEnabled(false) }
+  protected open fun setStandardBeepEnabled(enabled: Boolean) {}
   open suspend fun pause() { needScan = false }
   open suspend fun release() { needScan = false }
 }

