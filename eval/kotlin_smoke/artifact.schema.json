{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docatlas.local/schemas/kotlin-smoke-1.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "mode", "command", "docatlas_commit", "source_ref",
    "elapsed_ms", "terminal_status", "citations", "requested_version",
    "resolved_version", "canonical_source_identity", "query", "code_match", "recorded_at"
  ],
  "properties": {
    "schema_version": {"const": "kotlin-smoke-1.0"},
    "mode": {"enum": ["fixture", "live"]},
    "command": {"type": "string", "minLength": 1},
    "docatlas_commit": {"type": "string", "minLength": 1},
    "source_ref": {"type": "string", "pattern": "^Kotlin/kotlinx\\.coroutines@"},
    "elapsed_ms": {"type": "integer", "minimum": 0},
    "terminal_status": {"enum": ["succeeded", "partial"]},
    "citations": {
      "type": "array", "minItems": 1, "maxItems": 20,
      "items": {"type": "string", "pattern": "^https://"}
    },
    "requested_version": {"type": "string", "minLength": 1},
    "resolved_version": {"type": "string", "minLength": 1},
    "canonical_source_identity": {"type": "string", "minLength": 1},
    "query": {"const": "coroutines launch async example with code"},
    "code_match": {"const": true},
    "recorded_at": {"type": "string", "format": "date-time"}
  }
}
